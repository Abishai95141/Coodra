{
  "name": "contextos",
  "version": "0.0.0",
  "private": true,
  "description": "ContextOS — MCP server platform providing Feature Packs, Context Packs, and policy enforcement for AI coding agents.",
  "license": "MIT",
  "author": "Abishai <abishai95141@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abishai95141/Coodra.git"
  },
  "homepage": "https://github.com/Abishai95141/Coodra#readme",
  "bugs": {
    "url": "https://github.com/Abishai95141/Coodra/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.16.0 <23",
    "pnpm": ">=10.33.0 <11"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm test:unit",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome",
      "better-sqlite3"
    ]
  }
}
